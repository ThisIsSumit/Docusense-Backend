{
  "name": "docusense-backend",
  "version": "1.0.0",
  "description": "DocuSense AI Document Intelligence API",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "dev:api": "tsx watch src/main.ts",
    "dev:worker": "tsx src/jobs/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "worker": "tsx src/jobs/worker.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "dependencies": {
    "@google/genai": "^0.13.0",
    "@prisma/client": "^5.14.0",
    "@supabase/supabase-js": "^2.53.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.8",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.5",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "uuid": "^9.0.1",
    "voyageai": "^0.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.11.6",
    "@types/serve-static": "^2.2.0",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.14.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
