generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "public"), uuid_ossp(map: "uuid-ossp")]
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email          String    @unique
  name           String
  passwordHash   String    @map("password_hash")
  avatarUrl      String?   @map("avatar_url")
  documentsCount Int       @default(0) @map("documents_count")
  queriesCount   Int       @default(0) @map("queries_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastLoginAt    DateTime? @map("last_login_at")

  documents Document[]
  sessions  Session[]
  queries   Query[]

  @@map("users")
}

model Session {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

model Document {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  title         String
  fileName      String         @map("file_name")
  mimeType      String         @map("mime_type")
  fileSizeBytes Int            @map("file_size_bytes")
  storageKey    String         @map("storage_key")
  status        DocumentStatus @default(PENDING)
  summary       String?
  thumbnailUrl  String?        @map("thumbnail_url")
  tags          String[]       @default([])
  pageCount     Int            @default(0) @map("page_count")
  queryCount    Int            @default(0) @map("query_count")
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  processedAt   DateTime?      @map("processed_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks Chunk[]
  queries Query[]

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("documents")
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model Chunk {
  id         String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  documentId String                  @map("document_id") @db.Uuid
  content    String
  pageNumber Int?                    @map("page_number")
  chunkIndex Int                     @map("chunk_index")
  embedding  Unsupported("vector(1024)")?
  metadata   Json                    @default("{}")
  createdAt  DateTime                @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("chunks")
}

model Query {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  documentId   String?  @map("document_id") @db.Uuid
  question     String
  answer       String
  sourceChunks Json     @default("[]") @map("source_chunks")
  tokensUsed   Int      @default(0) @map("tokens_used")
  latencyMs    Int      @default(0) @map("latency_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id])

  @@index([userId])
  @@index([documentId])
  @@map("queries")
}
